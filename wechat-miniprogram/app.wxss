page {
  background: #f7f8fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  min-height: 100vh;
}

button {
  font-size: 28rpx;
}

.page {
  box-sizing: border-box;
  padding: 28rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 20rpx;
  box-shadow: 0 16rpx 50rpx rgba(15, 23, 42, 0.06);
}

.primary-button {
  background: #1976d2;
  border-radius: 14rpx;
  color: #ffffff;
}

.outline-button {
  background: #ffffff;
  border: 1rpx solid #cfd8e3;
  border-radius: 14rpx;
  color: #25324b;
}

.danger-button {
  background: #d32f2f;
  border-radius: 14rpx;
  color: #ffffff;
}

.muted {
  color: #667085;
}
