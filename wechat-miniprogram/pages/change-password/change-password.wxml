<view class="page password-page">
  <view class="panel password-panel">
    <view class="title">修改密码</view>
    <view class="subtitle">修改后下次登录请使用新密码。</view>

    <view wx:if="{{error}}" class="error-box">{{error}}</view>

    <view class="field">
      <text>当前密码</text>
      <input password value="{{currentPassword}}" data-field="currentPassword" bindinput="handleInput" />
    </view>

    <view class="field">
      <text>新密码</text>
      <input password value="{{nextPassword}}" data-field="nextPassword" bindinput="handleInput" placeholder="至少 8 位" />
    </view>

    <view class="field">
      <text>确认新密码</text>
      <input password value="{{confirmPassword}}" data-field="confirmPassword" bindinput="handleInput" />
    </view>

    <button class="primary-button submit-button" loading="{{isLoading}}" bindtap="submit">保存新密码</button>
  </view>
</view>
