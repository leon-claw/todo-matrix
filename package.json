{
  "name": "todo-matrix",
  "private": true,
  "version": "1.1.0",
  "description": "Todo Matrix desktop and web app",
  "author": "Todo Matrix Contributors",
  "type": "module",
  "main": ".vite/build/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --configLoader runner",
    "dev:client": "vite --host 127.0.0.1 --configLoader runner",
    "dev:prod-api": "vite --host 127.0.0.1 --mode prod-api --strictPort --configLoader runner",
    "dev:server": "tsx watch server/src/index.ts",
    "start:private": "prisma migrate deploy && node --import tsx server/src/index.ts",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "build": "tsc -b && vite build --configLoader runner",
    "build:android:ota": "node scripts/build-android-ota.mjs",
    "build:windows:ota": "node scripts/build-windows-ota.mjs",
    "release:ota": "node scripts/release-ota.mjs",
    "release:build:windows": "powershell -ExecutionPolicy Bypass -File scripts/release/build-windows.ps1",
    "release:build:mac": "bash scripts/release/build-mac.sh",
    "release:github": "node scripts/release/github-release.mjs",
    "build:wechat": "node scripts/build-wechat-miniprogram.mjs",
    "desktop:dev": "electron-forge start",
    "desktop:dev:proxy": "node scripts/run-electron-forge-with-proxy.mjs start",
    "desktop:make": "electron-forge make",
    "desktop:make:proxy": "node scripts/run-electron-forge-with-proxy.mjs make",
    "desktop:package": "electron-forge package",
    "desktop:package:proxy": "node scripts/run-electron-forge-with-proxy.mjs package",
    "build:android": "vite build --mode android --configLoader runner && cap sync android",
    "android:init": "cap add android",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "preview": "vite preview --host 127.0.0.1",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capgo/capacitor-updater": "^7.45.10",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "adm-zip": "^0.5.17",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "echarts": "^5.6.0",
    "express": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@types/adm-zip": "^0.5.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.15.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
